{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"*.{json,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" \"*.{json,js}\"",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "test": "ng test --watch=false",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --watch=false --coverage",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "docker:up": "docker compose -f ../docker/compose.yml --env-file ../docker/.env up -d db",
    "docker:down": "docker compose -f ../docker/compose.yml --env-file ../docker/.env down"
  },
  "private": true,
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=22.12 <25",
    "npm": ">=11 <12"
  },
  "dependencies": {
    "@angular/animations": "21.2.18",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "primeng": "^21.1.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.18",
    "@angular/cli": "21.2.18",
    "@angular/compiler-cli": "21.2.18",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "primeicons": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.0.8"
  }
}
