# ============================================================================
# Lembas Docker stack environment variables.
# Copy this file to `.env` and fill in the values before running the stack.
#   cd docker
#   cp .env.example .env
#   docker compose --env-file .env up -d --build
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
DB_NAME=lembas
DB_USER=lembas
# Change this before exposing the database outside the host.
DB_PASSWORD=change-this-database-password
DB_PORT=5432
# Bind PostgreSQL to localhost by default. Use 0.0.0.0 only if remote access is required.
DB_BIND_ADDRESS=127.0.0.1

# ----------------------------------------------------------------------------
# JWT authentication
# ----------------------------------------------------------------------------
# Use a strong 256-bit or longer value in production. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-256-bits

# ----------------------------------------------------------------------------
# Spring profile and JVM
# ----------------------------------------------------------------------------
# Use prod for the full deployment stack, dev for local hot reload, test for
# automated test runs.
SPRING_PROFILES_ACTIVE=prod

# Container-aware memory limits for the JVM.
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport

# ----------------------------------------------------------------------------
# Public web port exposed by Nginx.
# ----------------------------------------------------------------------------
WEB_PORT=80

# ----------------------------------------------------------------------------
# Mercado Pago Checkout Pro
#
# Two supported modes (select with PAYMENTS_GATEWAY):
#   * fake       (default) -- the in-memory FakePaymentGateway is used and the
#                            values below can be left blank. This is the
#                            recommended setting for local dev and CI.
#   * mercadopago            -- the real MercadoPagoGateway is wired and
#                            MP_ACCESS_TOKEN / MP_WEBHOOK_SECRET become
#                            mandatory (the app fails fast at startup if
#                            they are blank).
#
# When you switch to mercadopago, set the URLs to the public origin the
# customer is redirected to and where MP can POST notifications:
#   * MP_SUCCESS_URL / MP_FAILURE_URL / MP_PENDING_URL -- redirect targets
#     after the hosted checkout completes.
#   * MP_NOTIFICATION_URL -- the public webhook URL. For local sandbox
#     testing this is the ngrok tunnel URL (see the mp-sandbox override
#     in this directory and the README).
# ----------------------------------------------------------------------------
PAYMENTS_GATEWAY=fake
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=http://localhost:8080/api/webhooks/mercadopago
MP_SUCCESS_URL=http://localhost/customer/payment/callback
MP_FAILURE_URL=http://localhost/customer/payment/callback
MP_PENDING_URL=http://localhost/customer/payment/callback

# ----------------------------------------------------------------------------
# ngrok (only used by docker/mp-sandbox.override.yml)
#
# Free ngrok account: https://dashboard.ngrok.com/signup
# Authtoken          : https://dashboard.ngrok.com/get-started/your-authtoken
#
# The override starts an ngrok container that exposes the backend service
# at https://<random>.ngrok-free.app. Mercado Pago then delivers the
# webhook to https://<random>.ngrok-free.app/api/webhooks/mercadopago, and
# the backend (running inside Docker) receives it as a normal
# POST /api/webhooks/mercadopago call.
#
# Leave NGROK_AUTHTOKEN blank if you do not intend to use the mp-sandbox
# override; the main stack does not depend on it.
# ----------------------------------------------------------------------------
NGROK_AUTHTOKEN=
# Local port for the ngrok web inspection UI (http://localhost:4040).
# Comment out the port mapping in mp-sandbox.override.yml if you do not
# need it.
NGROK_WEB_PORT=4040
