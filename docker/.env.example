# ============================================================================
# Lembas Docker stack environment variables.
# Copy this file to `.env` and fill in the values before running the stack.
#   cd docker
#   cp .env.example .env
#   docker compose --env-file .env up -d --build
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
DB_NAME=lembas
DB_USER=lembas
# Change this before exposing the database outside the host.
DB_PASSWORD=change-this-database-password
DB_PORT=5432
# Bind PostgreSQL to localhost by default. Use 0.0.0.0 only if remote access is required.
DB_BIND_ADDRESS=127.0.0.1

# ----------------------------------------------------------------------------
# JWT authentication
# ----------------------------------------------------------------------------
# Use a strong 256-bit or longer value in production. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-256-bits

# ----------------------------------------------------------------------------
# Spring profile and JVM
# ----------------------------------------------------------------------------
# Use prod for the full deployment stack, dev for local hot reload, test for
# automated test runs.
SPRING_PROFILES_ACTIVE=prod

# Container-aware memory limits for the JVM.
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport

# ----------------------------------------------------------------------------
# Public web port exposed by Nginx.
# ----------------------------------------------------------------------------
WEB_PORT=80

# ----------------------------------------------------------------------------
# Mercado Pago Checkout Pro
#
# The application always uses the real Mercado Pago SDK gateway; there is no
# in-memory alternative. MP_ACCESS_TOKEN and MP_WEBHOOK_SECRET are mandatory
# and the application fails fast at startup if either is blank.
#
# Set the URLs to the public origin the customer is redirected to and where
# MP can POST notifications:
#   * MP_SUCCESS_URL / MP_FAILURE_URL / MP_PENDING_URL -- redirect targets
#     after the hosted checkout completes.
#   * MP_NOTIFICATION_URL -- the public webhook URL. For local sandbox
#     testing this is the ngrok tunnel URL obtained from the ngrok service
#     logs after startup (see the ngrok section below).
# ----------------------------------------------------------------------------
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=http://localhost:8080/api/webhooks/mercadopago
MP_SUCCESS_URL=http://localhost/customer/payment/callback
MP_FAILURE_URL=http://localhost/customer/payment/callback
MP_PENDING_URL=http://localhost/customer/payment/callback

# ----------------------------------------------------------------------------
# ngrok (part of the main stack; skips gracefully when left empty)
#
# Free ngrok account: https://dashboard.ngrok.com/signup
# Authtoken          : https://dashboard.ngrok.com/get-started/your-authtoken
#
# The ngrok container starts automatically with the stack. If NGROK_AUTHTOKEN
# is set, it opens a tunnel at https://<random>.ngrok-free.app that exposes
# the web container (and thus the backend via nginx) to the public internet.
# Mercado Pago can then deliver webhook notifications to:
#   https://<random>.ngrok-free.app/api/webhooks/mercadopago
#
# If NGROK_AUTHTOKEN is left empty, the container prints a reminder message
# and pauses harmlessly (no error, no tunnel).
#
# Workflow to enable MP sandbox:
#   1. Set NGROK_AUTHTOKEN, MP_ACCESS_TOKEN, and MP_WEBHOOK_SECRET in .env.
#   2. Start or recreate the stack:
#        docker compose --env-file .env up -d --build
#   3. Get the public URL from the ngrok logs:
#        docker compose --env-file .env logs ngrok
#      Look for:  msg="started tunnel" object-url="https://abc.ngrok-free.app"
#   4. Set MP_NOTIFICATION_URL in .env to:
#        https://abc.ngrok-free.app/api/webhooks/mercadopago
#   5. Restart the backend:
#        docker compose --env-file .env up -d --force-recreate backend
#   6. Register the webhook in the Mercado Pago Developers panel using the
#      same URL and MP_WEBHOOK_SECRET from step 1.
# ----------------------------------------------------------------------------
NGROK_AUTHTOKEN=
# Local port for the ngrok web inspection UI (http://localhost:4040).
NGROK_WEB_PORT=4040
