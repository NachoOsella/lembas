# Database
DB_NAME=lembas
DB_USER=lembas
DB_PASSWORD=change-this-database-password
DB_PORT=5432
# Bind PostgreSQL to localhost by default. Use 0.0.0.0 only if remote access is required.
DB_BIND_ADDRESS=127.0.0.1

# JWT authentication. Use a strong 256-bit or longer value in production.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-256-bits

# Spring profile. Use prod for the full deployment stack.
SPRING_PROFILES_ACTIVE=prod

# JVM options for container-aware memory usage.
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport

# Public web port exposed by Nginx.
WEB_PORT=80

# Mercado Pago. Required when the prod payment gateway is enabled.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_SUCCESS_URL=http://localhost/customer/payment/callback
MP_FAILURE_URL=http://localhost/customer/payment/callback
MP_PENDING_URL=http://localhost/customer/payment/callback
