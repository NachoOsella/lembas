# Keep Docker build contexts small and deterministic.
.git
.gitignore

# Local environment files must not be copied into images.
.env
.env.*
!*.env.example

# Backend build outputs and local uploads.
backend/target
backend/uploads

# Frontend dependencies, build outputs, and caches.
frontend/node_modules
frontend/dist
frontend/.angular/cache
frontend/coverage

# Editor and OS files.
.idea
.vscode
.DS_Store
*.swp

# Logs and temporary files.
*.log
tmp
temp
